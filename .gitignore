# Python bytecode
__pycache__/
*.pyc
*.pyo

# Testing caches
.pytest_cache/

# Type checking cache
.mypy_cache/

# Generated output directories
output/
tmp_output*/
tmp_output_ingestion*/

# IDE configs (should not be tracked)
.claude/
.kiro/

# Build/distribution artifacts
*.egg-info/
dist/
build/

# Virtual environments
.venv/
venv/
env/

# OS-specific files
Thumbs.db
Desktop.ini
.DS_Store

# Editor files
*.swp
*.swo
*~

# Environment secrets (NEVER commit)
.env
.env.*
!.env.example

# Archive temporary outputs
archive/tmp_output*/
archive/test_output*/
archive/out/
archive/memory/
archive/*.log
archive/*.txt
archive/.coverage
archive/*_loop.json
