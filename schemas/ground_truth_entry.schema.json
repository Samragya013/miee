{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MIIE Ground Truth Entry Schema",
  "description": "Schema for individual ground truth entries within a dataset",
  "type": "object",
  "required": [
    "entry_id",
    "dataset_id",
    "window_index",
    "expected_values"
  ],
  "properties": {
    "entry_id": {
      "type": "string",
      "pattern": "^GT-E-\\d{4}$",
      "description": "Unique entry identifier"
    },
    "dataset_id": {
      "type": "string",
      "pattern": "^GT-(SYN|REAL|ADV)-[A-Z_]+-\\d{3}$",
      "description": "Parent dataset identifier"
    },
    "window_index": {
      "type": "integer",
      "minimum": 0,
      "description": "Window index for this entry"
    },
    "expected_values": {
      "type": "object",
      "properties": {
        "metrics": {
          "type": "object",
          "description": "Expected metric values for this window"
        },
        "detectors": {
          "type": "object",
          "description": "Expected detector outputs for this window"
        },
        "scores": {
          "type": "object",
          "description": "Expected scores for this window"
        }
      }
    },
    "annotations": {
      "type": "object",
      "properties": {
        "anomaly_present": {
          "type": "boolean",
          "description": "Whether anomaly is present in this window"
        },
        "anomaly_type": {
          "type": "string",
          "enum": [
            "metric-drift",
            "correlation-breakdown",
            "threshold-compression",
            "seasonal",
            "gaming",
            "process-decay"
          ]
        },
        "severity": {
          "type": "string",
          "enum": ["none", "low", "moderate", "high", "critical"]
        },
        "notes": {
          "type": "string",
          "description": "Annotator notes"
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence in this entry's ground truth"
    },
    "source": {
      "type": "string",
      "enum": ["automated", "expert", "mixed"],
      "description": "Source of ground truth"
    }
  }
}
