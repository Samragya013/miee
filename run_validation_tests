#!/usr/bin/env python3
"""
Validation script for MIIE system.
Runs the test suite and returns success rate.
"""
import subprocess
import sys
import re

def run_validation_tests():
    """Run the MIIE test suite and return success rate."""
    try:
        # Run pytest and capture output
        result = subprocess.run([
            sys.executable, "-m", "pytest", "tests/", "-v", "--tb=short",
            "--ignore=tests/integration/test_segmentation_integration.py",
            "--ignore=tests/performance/test_profiling.py",
            "--ignore=tests/workflow/test_reproducibility.py",
            "--ignore=tests/workflow/test_workflows.py"
        ], capture_output=True, text=True, timeout=120)

        # Parse the output to extract pass/fail counts
        # Look for lines like "=== 5 passed, 2 failed in 3.21s ==="
        output = result.stdout + result.stderr
        match = re.search(r'(\d+) passed(?:, (\d+) failed)?', output)

        if match:
            passed = int(match.group(1))
            failed = int(match.group(2)) if match.group(2) else 0
            total = passed + failed

            if total > 0:
                success_rate = passed / total
            else:
                success_rate = 0.0

            print(f"Validation: {passed} passed, {failed} failed, success_rate={success_rate:.3f}")
            return success_rate
        else:
            # If we can't parse, check return code
            if result.returncode == 0:
                print("Validation: All tests passed (parsed from return code)")
                return 1.0
            else:
                print("Validation: Some tests failed (parsed from return code)")
                return 0.0

    except subprocess.TimeoutExpired:
        print("Validation: Tests timed out")
        return 0.0
    except Exception as e:
        print(f"Validation: Error running tests: {e}")
        return 0.0

if __name__ == "__main__":
    success_rate = run_validation_tests()
    # Output just the success rate for the experiment tracker
    print(f"RESULT: {success_rate}")