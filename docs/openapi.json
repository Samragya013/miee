{
  "openapi": "3.1.0",
  "info": {
    "title": "MIIE API",
    "description": "Measurement Integrity Intelligence Engine",
    "version": "1.6.0"
  },
  "paths": {
    "/v1/health": {
      "get": {
        "tags": [
          "system"
        ],
        "summary": "Health Check",
        "description": "Return service health (TFS \u00a714.3).",
        "operationId": "health_check_v1_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/analyze": {
      "post": {
        "tags": [
          "analysis"
        ],
        "summary": "Analyze",
        "description": "Accept an analysis job and run it in the background (TFS \u00a714.3).",
        "operationId": "analyze_v1_analyze_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnalyzeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobAccepted"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/jobs/{job_id}": {
      "get": {
        "tags": [
          "jobs"
        ],
        "summary": "Get Job Status",
        "description": "Return job status \u2014 200 if completed, 202 if running (TFS \u00a714.3).",
        "operationId": "get_job_status_v1_jobs__job_id__get",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/jobs/{job_id}/results": {
      "get": {
        "tags": [
          "jobs"
        ],
        "summary": "Get Job Results",
        "description": "Return full analysis results (TFS \u00a714.3).",
        "operationId": "get_job_results_v1_jobs__job_id__results_get",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/benchmark": {
      "post": {
        "tags": [
          "benchmark"
        ],
        "summary": "Benchmark",
        "description": "Accept a benchmark job and run it in the background (TFS \u00a714.3).",
        "operationId": "benchmark_v1_benchmark_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BenchmarkRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobAccepted"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/explain": {
      "post": {
        "tags": [
          "analysis"
        ],
        "summary": "Explain",
        "description": "Generate an explanation from a completed analysis (TFS \u00a714.3).",
        "operationId": "explain_v1_explain_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExplainRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExplainResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/export": {
      "post": {
        "tags": [
          "export"
        ],
        "summary": "Export",
        "description": "Export results in specified formats (TFS \u00a714.3).",
        "operationId": "export_v1_export_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExportRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExportResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AnalyzeRequest": {
        "properties": {
          "repo": {
            "type": "string",
            "minLength": 1,
            "title": "Repo",
            "description": "Repository path or URL"
          },
          "since": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Since",
            "description": "ISO 8601 start date"
          },
          "until": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Until",
            "description": "ISO 8601 end date"
          },
          "metrics": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Metrics"
          },
          "window_strategy": {
            "type": "string",
            "pattern": "^(time|commit|release|custom)$",
            "title": "Window Strategy",
            "default": "time"
          },
          "window_size": {
            "type": "integer",
            "minimum": 1.0,
            "title": "Window Size",
            "default": 7
          },
          "detectors": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Detectors"
          },
          "output_formats": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Output Formats"
          },
          "exclude_bots": {
            "type": "boolean",
            "title": "Exclude Bots",
            "default": false
          },
          "thresholds": {
            "additionalProperties": true,
            "type": "object",
            "title": "Thresholds"
          },
          "detector_weights": {
            "additionalProperties": {
              "type": "number"
            },
            "type": "object",
            "title": "Detector Weights"
          },
          "seed": {
            "type": "integer",
            "title": "Seed",
            "default": 42
          },
          "output_dir": {
            "type": "string",
            "title": "Output Dir",
            "default": "./output"
          }
        },
        "type": "object",
        "required": [
          "repo"
        ],
        "title": "AnalyzeRequest",
        "description": "POST /v1/analyze request body (TFS \u00a714.3)."
      },
      "BenchmarkRequest": {
        "properties": {
          "suite": {
            "type": "string",
            "minLength": 1,
            "title": "Suite",
            "description": "Benchmark suite ID"
          },
          "detectors": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Detectors"
          },
          "config_overrides": {
            "additionalProperties": true,
            "type": "object",
            "title": "Config Overrides"
          },
          "seed": {
            "type": "integer",
            "title": "Seed",
            "default": 42
          },
          "output_formats": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Output Formats"
          }
        },
        "type": "object",
        "required": [
          "suite"
        ],
        "title": "BenchmarkRequest",
        "description": "POST /v1/benchmark request body (TFS \u00a714.3)."
      },
      "ExplainRequest": {
        "properties": {
          "job_id": {
            "type": "string",
            "minLength": 1,
            "title": "Job Id",
            "description": "Job ID of completed analysis"
          },
          "metric": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Metric",
            "description": "Specific metric to explain"
          },
          "detector": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Detector",
            "description": "Specific detector to explain"
          },
          "format": {
            "type": "string",
            "pattern": "^(md|json)$",
            "title": "Format",
            "default": "json"
          }
        },
        "type": "object",
        "required": [
          "job_id"
        ],
        "title": "ExplainRequest",
        "description": "POST /v1/explain request body (TFS \u00a714.3)."
      },
      "ExplainResponse": {
        "properties": {
          "explanation": {
            "type": "string",
            "title": "Explanation"
          },
          "rule_fired": {
            "type": "string",
            "title": "Rule Fired"
          },
          "evidence_refs": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Evidence Refs"
          },
          "metric": {
            "type": "string",
            "title": "Metric"
          },
          "detector": {
            "type": "string",
            "title": "Detector"
          }
        },
        "type": "object",
        "required": [
          "explanation",
          "rule_fired",
          "evidence_refs",
          "metric",
          "detector"
        ],
        "title": "ExplainResponse",
        "description": "POST /v1/explain response (TFS \u00a714.3)."
      },
      "ExportRequest": {
        "properties": {
          "job_id": {
            "type": "string",
            "minLength": 1,
            "title": "Job Id",
            "description": "Job ID of completed analysis"
          },
          "formats": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Formats"
          },
          "filter": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Filter"
          }
        },
        "type": "object",
        "required": [
          "job_id"
        ],
        "title": "ExportRequest",
        "description": "POST /v1/export request body (TFS \u00a714.3)."
      },
      "ExportResponse": {
        "properties": {
          "download_urls": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object",
            "title": "Download Urls"
          }
        },
        "type": "object",
        "required": [
          "download_urls"
        ],
        "title": "ExportResponse",
        "description": "POST /v1/export response (TFS \u00a714.3)."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "version": {
            "type": "string",
            "title": "Version"
          },
          "uptime_seconds": {
            "type": "number",
            "title": "Uptime Seconds"
          }
        },
        "type": "object",
        "required": [
          "status",
          "version",
          "uptime_seconds"
        ],
        "title": "HealthResponse",
        "description": "GET /v1/health response (TFS \u00a714.3)."
      },
      "JobAccepted": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "poll_url": {
            "type": "string",
            "title": "Poll Url"
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "status",
          "poll_url"
        ],
        "title": "JobAccepted",
        "description": "202 response for async job creation (TFS \u00a714.3)."
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}